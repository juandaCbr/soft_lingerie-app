# Copia este archivo a .env y rellena los valores reales.
#   Windows (PowerShell): Copy-Item .env_example .env
#   macOS / Linux:        cp .env_example .env

# --- Supabase ---
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Clave de servicio (solo servidor; no exponer al cliente). Necesaria para APIs como check-email y register-guest.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Wompi (pagos) ---
# Usa las llaves de prueba o producción según tu entorno.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=your_wompi_public_key
NEXT_PUBLIC_WOMPI_INTEGRITY_SECRET=your_wompi_integrity_secret
NEXT_PUBLIC_WOMPI_API_URL=https://api.wompi.co/v1
WOMPI_PRIVATE_KEY=your_wompi_private_key
WOMPI_EVENTS_SECRET=your_wompi_events_secret

# --- Notificaciones (Pushover principal, opcional) ---
# Crea tu app/token en https://pushover.net/apps y usa tu USER KEY.
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_api_token

# --- App ---
# URL pública del sitio (redirects de Auth, enlaces en emails). En local suele ser http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Carpeta local para subida de imágenes (si aplica)
UPLOAD_DIR=./uploads
