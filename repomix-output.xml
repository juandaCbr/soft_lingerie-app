<file path="components/BotonWompi.tsx">
"use client";

import { useEffect, useState } from 'react';
import { CreditCard, Loader2 } from 'lucide-react';

declare global {
    interface Window {
        WidgetCheckout: any;
    }
}

interface BotonWompiProps {
    montoTotal: number;
    referenciaPedido: string;
    onExito: (transaccion: any) => void;
}

export default function BotonWompi({ montoTotal, referenciaPedido, onExito }: BotonWompiProps) {
    const [cargando, setCargando] = useState(true);

    useEffect(() => {
        if (window.WidgetCheckout) {
            setCargando(false);
            return;
        }

        const script = document.createElement('script');
        script.src = "https://checkout.wompi.co/widget.js";
        script.async = true;

        script.onload = () => {
            console.log("✅ Wompi cargado manualmente");
            setCargando(false);
        };

        script.onerror = () => {
            console.error("❌ Error cargando el script de Wompi");
        };

        document.body.appendChild(script);

        return () => {
            if (document.body.contains(script)) {
                // Opcional: limpiar script
            }
        };
    }, []);

    const abrirWidgetWompi = () => {
        if (typeof window !== 'undefined' && window.WidgetCheckout) {

            // 1. Validamos que el monto sea un número válido y mayor a 0
            if (!montoTotal || isNaN(montoTotal) || montoTotal <= 0) {
                console.error("❌ Error: El monto total es inválido:", montoTotal);
                alert("Hubo un error calculando el total a pagar.");
                return;
            }

            const montoEnCentavos = Math.round(montoTotal * 100);
            const referenciaUnica = `${referenciaPedido}_${Date.now()}`;

            // 2. Imprimimos en consola lo que le vamos a enviar a Wompi
            console.log("📤 Enviando a Wompi:", {
                montoOriginal: montoTotal,
                montoEnCentavos: montoEnCentavos,
                referencia: referenciaUnica
            });

            const checkout = new window.WidgetCheckout({
                currency: 'COP',
                amountInCents: montoEnCentavos,
                reference: referenciaUnica,
                // 🔥 AQUÍ ESTABA EL ERROR: Cambiamos el 1 por la l minúscula
                publicKey: 'pub_test_ZeQynhklPQ2b3TqOjxFeT2uhKvwPNnv5',
            });

            checkout.open((resultado: any) => {
                if (resultado.transaction && resultado.transaction.status === 'APPROVED') {
                    onExito(resultado.transaction);
                }
            });
        } else {
            alert("La pasarela aún no está lista.");
        }
    };

    return (
        <button
            onClick={abrirWidgetWompi}
            disabled={cargando}
            type="button"
            className="w-full bg-[#4a1d44] text-white py-4 rounded-xl text-[11px] font-black tracking-[0.2em] flex items-center justify-center gap-3 mt-4 shadow-xl hover:bg-[#5c2454] active:scale-95 transition-all uppercase disabled:opacity-50"
        >
            {cargando ? (
                <><Loader2 className="animate-spin" size={18} /> Configurando pago...</>
            ) : (
                <><CreditCard size={18} /> PAGAR PEDIDO</>
            )}
        </button>
    );
}
