import { createClient } from '@supabase/supabase-js';

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
const supabaseKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY;

if (!supabaseUrl || !supabaseKey) {
  console.error('Missing Supabase credentials');
  process.exit(1);
}

const supabase = createClient(supabaseUrl, supabaseKey);

async function getStructure() {
  console.log('Checking structure...');
  
  // Try to get products to see its structure
  const { data: pData, error: pError } = await supabase.from('productos').select('*').limit(1);
  if(pError) {
    console.log('Error querying productos:', pError.message)
  } else if (pData && pData.length > 0) {
    console.log('Structure of table \
productos\:', Object.keys(pData[0]));
    console.log('Data sample:', pData[0]);
  } else {
      console.log('Table \productos\ is empty or accessible but no rows returned.');
  }
}

getStructure();
