<file path="app/page.tsx">
"use client";

import { useEffect, useState } from 'react';
import { supabase } from './lib/supabase';
import Link from 'next/link';
import { ArrowRight, Star, Clock, Loader2 } from 'lucide-react';

export default function HomePage() {
  const [novedades, setNovedades] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [mounted, setMounted] = useState(false);

  useEffect(() => {
    setMounted(true);
    const fetchNovedades = async () => {
      try {
        const { data } = await supabase
          .from('productos')
          .select('*')
          .eq('activo', true)
          .order('created_at', { ascending: false })
          .limit(4); // Traemos 4 para que el grid de 2x2 en móvil quede perfecto
        setNovedades(data || []);
      } catch (error) {
        console.error(error);
      } finally {
        setLoading(false);
      }
    };
    fetchNovedades();
  }, []);

  return (
    <div className="bg-[#fdf8f6] min-h-screen w-full overflow-x-hidden">
      
      {/* HERO SECTION - Ajustada para iPhone */}
      <section className="relative h-[75vh] w-full bg-[#4a1d44] overflow-hidden flex items-center justify-center text-center px-4">
  <div className="absolute inset-0 opacity-40">
      <img 
        // Solo pones la barra diagonal y el nombre exacto del archivo
        src="/home.jpg" 
        className="w-full h-full object-cover" 
        alt="Nueva Colección Lencería" 
      />
  </div>
        <div className="relative z-10 max-w-3xl">
          <h1 className="text-4xl md:text-7xl font-bold text-white mb-4 tracking-tighter leading-tight font-playfair">
            Siente la Elegancia
          </h1>
          <p className="text-white/80 text-sm md:text-xl mb-8 italic font-light">
            Colecciones exclusivas diseñadas para resaltar tu confianza.
          </p>
          <Link href="/productos" className="bg-white text-[#4a1d44] px-8 py-4 rounded-full font-bold text-xs md:text-base hover:scale-105 transition shadow-xl inline-flex items-center gap-2 uppercase tracking-widest">
            Explorar Colección <ArrowRight size={18} />
          </Link>
        </div>
      </section>

      {/* SECCIÓN NOVEDADES */}
      <section className="max-w-7xl mx-auto py-16 md:py-24 px-4 md:px-6">
        <div className="flex items-center justify-center md:justify-start gap-3 mb-10">
          <Clock className="text-[#4a1d44]" size={20} />
          <h2 className="text-2xl md:text-4xl font-bold text-[#4a1d44] font-playfair uppercase tracking-tight">Lo más Nuevo</h2>
        </div>
        
        {loading ? (
          <div className="flex justify-center py-20">
            <Loader2 className="animate-spin text-[#4a1d44]/20" size={40} />
          </div>
        ) : (
          /* GRID RESPONSIVE: 2 columnas en móvil, 4 en desktop */
          <div className="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
            {novedades.map(prod => {
              // Lógica para detectar imagen
              const fotoUrl = Array.isArray(prod.imagenes_urls) && prod.imagenes_urls.length > 0 
                ? prod.imagenes_urls[0] 
                : prod.imagen_url;

              return (
                <Link href="/productos" key={prod.id} className="group cursor-pointer flex flex-col h-full">
                  {/* Contenedor de la imagen */}
                  <div className="relative aspect-[2/3] rounded-2xl overflow-hidden mb-3 shadow-md bg-white">
                    {fotoUrl ? (
                      <img 
                        src={fotoUrl} 
                        className="w-full h-full object-cover group-hover:scale-110 transition duration-500" 
                        alt={prod.nombre} 
                      />
                    ) : (
                      <div className="w-full h-full flex items-center justify-center opacity-10"><Star /></div>
                    )}
                    
                    {/* Etiqueta de Categoría (Solo si existe) */}
                    {prod.categoria && (
                      <span className="absolute top-2 left-2 bg-white/90 backdrop-blur-sm text-[#4a1d44] text-[8px] md:text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-full shadow-sm z-10">
                        {typeof prod.categoria === 'object' ? prod.categoria.nombre : prod.categoria}
                      </span>
                    )}

                    <div className="absolute bottom-2 left-2 bg-[#4a1d44] px-2 py-1 rounded-full text-[8px] md:text-[9px] font-bold text-white z-10">
                      NUEVO
                    </div>
                  </div>

                  {/* Textos debajo de la foto */}
                  <div className="text-center md:text-left">
                    <h3 className="font-bold text-xs md:text-lg text-[#4a1d44] truncate px-1">{prod.nombre}</h3>
                    <p className="text-[#4a1d44]/60 text-[10px] md:text-base font-black" suppressHydrationWarning>
                      {mounted ? `$${Number(prod.precio).toLocaleString('es-CO')}` : `$${prod.precio}`}
                    </p>
                  </div>
                </Link>
              );
            })}
          </div>
        )}
      </section>

      {/* SECCIÓN MÁS VENDIDOS */}
      <section className="bg-[#f2e1d9]/30 py-20 px-4">
        <div className="max-w-7xl mx-auto text-center">
          <div className="flex justify-center items-center gap-2 mb-4">
             <Star className="text-yellow-500 fill-yellow-500" size={18} />
             <span className="font-bold tracking-widest text-[#4a1d44]/50 text-[10px]">BEST SELLERS</span>
          </div>
          <h2 className="text-3xl md:text-5xl font-bold mb-6 font-playfair text-[#4a1d44]">Favoritos de nuestras clientes</h2>
          <p className="text-[#4a1d44]/60 italic text-sm md:text-lg max-w-xl mx-auto">
            Pronto verás aquí los conjuntos que están marcando tendencia en todo el país.
          </p>
        </div>
      </section>
    </div>
  );
}
</file>

